# ==========================================
# 스윙 눌림목 검색기 v4.5 — 환경변수 설정
# ==========================================
# ⚠️  이 파일을 복사해 .env로 저장한 뒤 실제 값을 입력하세요.
#     cp .env.example .env

# 텔레그램 봇 토큰 (@BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# 채팅방 ID (여러 개면 콤마로 구분)
# 일반 채팅방:  123456789
# 토픽 그룹:    -1003872236237  (슈퍼그룹은 앞에 -100 붙음)
TELEGRAM_CHAT_IDS=your_chat_id_here

# 토픽(스레드) ID — 일반 채팅방이면 비워두세요
# https://t.me/c/3872236237/6/7  →  토픽 ID = 6
TELEGRAM_TOPIC_ID=

# 한국투자증권 KIS API
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here

# 투자 모드: paper(모의투자) 또는 real(실전투자)
KIS_MODE=paper
